{
  "description": "xyz-harness dev-flow gate enforcement — prevents skipping gate checks",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/harness-gate-hook.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/harness-gate-hook.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
